{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src/renderer",
    "outDir": "dist/renderer",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"]
    }
  },
  "include": ["src/renderer/**/*"]
}
