{
  "name": "opencli-bridge",
  "version": "0.1.0",
  "description": "OpenCLI Bridge - connects local CLI tools to AgentStudio",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "vite build --config vite.config.ts",
    "start": "npm run build && electron .",
    "dev": "concurrently \"tsc -p tsconfig.json -w\" \"vite --config vite.config.ts\" \"cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "dev:renderer": "vite --config vite.config.ts",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json",
    "clean": "rimraf dist release",
    "lint": "eslint src/ --ext .ts,.tsx",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@jackwener/opencli": "^1.5.8",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "auto-launch": "^5.0.6",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-spawn": "^7.0.3",
    "electron-updater": "^6.3.0",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typed-emitter": "^2.1.0",
    "ws": "^8.16.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/auto-launch": "^5.0.5",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
