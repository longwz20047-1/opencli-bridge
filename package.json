{
  "name": "opencli-bridge",
  "version": "0.1.0",
  "description": "OpenCLI Bridge - connects local CLI tools to AgentStudio",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && electron .",
    "dev": "tsc && electron .",
    "pack": "tsc && electron-builder --dir",
    "dist": "tsc && electron-builder",
    "dist:win": "tsc && electron-builder --win",
    "dist:mac": "tsc && electron-builder --mac",
    "dist:linux": "tsc && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist release",
    "lint": "eslint src/ --ext .ts,.tsx"
  },
  "dependencies": {
    "@jackwener/opencli": "^1.5.8",
    "auto-launch": "^5.0.6",
    "cross-spawn": "^7.0.3",
    "electron-updater": "^6.3.0",
    "typed-emitter": "^2.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/auto-launch": "^5.0.5",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.3.0",
    "vitest": "^4.1.2"
  }
}
